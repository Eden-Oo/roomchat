# Copy to .env and fill in your own values. Do NOT commit .env.

# MongoDB Atlas connection string. Without it the app still runs as a
# live in-memory chat, but messages are not persisted and no history is
# shown on join.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/roomchat?appName=Cluster0

# How many recent messages to replay when a user joins a room (default 50).
HISTORY_LIMIT=50
